<?xml version="1.0" encoding="UTF-8"?>
<!--
    Document   : company.xml
    Author     : Mario Lasluisa Castaño
    Description:
        Estructura de la tabla company.
-->
<tabla>
    <columna>
        <nombre>id</nombre>
        <tipo>serial</tipo>
        <nulo>NO</nulo>
        <defecto>nextval('company_id_seq'::regclass)</defecto>
    </columna>
    <columna>
        <nombre>idfactura</nombre>
        <tipo>integer</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>idcompany</nombre>
        <tipo>integer</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>consecutive</nombre>
        <tipo>integer</tipo>
        <nulo>NO</nulo>
    </columna>
    <restriccion>
        <nombre>company_consecutive_pkey</nombre>
        <consulta>PRIMARY KEY (id)</consulta>
    </restriccion>
    <restriccion>
        <nombre>ca_company_consecutive_idfactura</nombre>
        <consulta>FOREIGN KEY (idfactura)
            REFERENCES facturascli (idfactura)
            ON DELETE CASCADE ON UPDATE CASCADE</consulta>
    </restriccion>
    <restriccion>
        <nombre>ca_company_consecutive_idcompany</nombre>
        <consulta>FOREIGN KEY (idcompany)
            REFERENCES company (id)
            ON DELETE CASCADE ON UPDATE CASCADE</consulta>
    </restriccion>
</tabla>