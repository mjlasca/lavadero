    Description:
        Estructura de la tabla company.
-->
<tabla>
    <columna>
        <nombre>id</nombre>
        <tipo>serial</tipo>
        <nulo>NO</nulo>
        <defecto>nextval('company_id_seq'::regclass)</defecto>
    </columna>
    <columna>
        <nombre>nombre</nombre>
        <tipo>varchar(255)</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>cif</nombre>
        <tipo>varchar(20)</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>prefijo</nombre>
        <tipo>varchar(10)</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>ultmod</nombre>
        <tipo>timestamp</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>useredit</nombre>
        <tipo>varchar(150)</tipo>
        <nulo>NO</nulo>
    </columna>
    <columna>
        <nombre>codestado</nombre>
        <tipo>int(1)</tipo>
        <nulo>NO</nulo>
        <defecto>1</defecto>
    </columna>
    <columna>
        <nombre>idmetodopago</nombre>
        <tipo>integer</tipo>
        <nulo>YES</nulo>
    </columna>
    <columna>
        <nombre>noiva</nombre>
        <tipo>boolean</tipo>
        <nulo>YES</nulo>
        <defecto>false</defecto>
    </columna>
    <restriccion>
        <nombre>company_pkey</nombre>
        <consulta>PRIMARY KEY (id)</consulta>
    </restriccion>
    <restriccion>
        <nombre>ca_company_idmetodopago</nombre>
        <consulta>FOREIGN KEY (idmetodopago)
            REFERENCES metodospago (id)
            ON DELETE CASCADE ON UPDATE CASCADE</consulta>
    </restriccion>
</tabla>